        h1 { color: #FF6B35; border-bottom: 2px solid #FF6B35; padding-bottom: 5px; }
        h2 { color: #059669; margin-top: 25px; border-bottom: 1px solid #ddd; }
        h3 { color: #4F46E5; }
        .code-block { background-color: #f4f4f4; border: 1px solid #ddd; padding: 10px; font-family: 'Courier New', Courier, monospace; }
